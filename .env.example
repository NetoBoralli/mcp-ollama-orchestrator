# Copy to `.env` and adjust. All vars are prefixed ORCH_.

# --- Inference engine ---
ORCH_OLLAMA_HOST=http://localhost:11434
ORCH_MODEL=llama3.1:8b

# --- Context window (critical: Ollama silently truncates past this) ---
ORCH_NUM_CTX=32768
ORCH_TEMPERATURE=0.0

# --- Reliability ---
ORCH_REQUEST_TIMEOUT_S=120
ORCH_OLLAMA_MAX_RETRIES=3
ORCH_MAX_AGENT_TURNS=10

# --- MCP server registry ---
ORCH_MCP_CONFIG_PATH=mcp_servers.json
